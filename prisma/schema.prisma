// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  VENDOR
  FIELD_STAFF
  DOCTOR
  LABOR
  PATIENT
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PatientRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CampStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CampCategoryScope {
  RURAL
  MID_REGION
  METRO
}

enum EligibilityStatus {
  ELIGIBLE
  INELIGIBLE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  CANCELLED
}

enum QuestionnaireTierCode {
  TIER_0
  TIER_1
  TIER_2
}

enum MemberRole {
  FIELD_STAFF
  DOCTOR
}

enum AssignmentRole {
  FIELD_STAFF
  DOCTOR
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  FINALIZED
}

enum FileType {
  PDF
  EXCEL
  IMAGE
}

enum DeliveryChannel {
  SMS
  EMAIL
  IN_APP
}

model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  phone        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(PENDING)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  // Relations
  admin                  Admin?
  vendor                 Vendor?
  patient                Patient?
  rolePermissions        RolePermission[]
  vendorStaffAssignments VendorStaffAssignment[]
  campAssignments        CampStaffAssignment[]
  scannedVisits          PatientCampVisit[]
  assessments            Assessment[]
  reports                Report[]
  auditLogs              AuditLog[]
  notifications          Notification[]
  loginSessions          LoginSession[]

  @@map("users")
}

model RolePermission {
  id         String  @id @default(uuid())
  userId     String
  moduleName String
  canCreate  Boolean @default(false)
  canRead    Boolean @default(false)
  canUpdate  Boolean @default(false)
  canDelete  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleName])
  @@map("role_permissions")
}

model District {
  id           String @id @default(uuid())
  stateName    String
  districtName String
  code         String @unique

  // Relations
  admins   Admin[]
  vendors  Vendor[]
  patients Patient[]
  camps    Camp[]

  @@map("districts")
}

model Admin {
  id                    String   @id @default(uuid())
  userId                String   @unique
  createdBySuperAdminId String
  districtId            String
  entitlementMetadata   Json?
  createdAt             DateTime @default(now())

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  district         District  @relation(fields: [districtId], references: [id])
  vendors          Vendor[]
  approvedPatients Patient[]

  @@map("admins")
}

model Vendor {
  id                 String       @id @default(uuid())
  userId             String       @unique
  organizationName   String
  ngoType            String
  districtId         String
  registrationNumber String       @unique
  approvedByAdminId  String?
  approvedAt         DateTime?
  rejectionReason    String?
  status             VendorStatus @default(PENDING)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  district         District                @relation(fields: [districtId], references: [id])
  approvedBy       Admin?                  @relation(fields: [approvedByAdminId], references: [id])
  staffAssignments VendorStaffAssignment[]
  camps            Camp[]

  @@map("vendors")
}

model VendorStaffAssignment {
  id         String     @id @default(uuid())
  vendorId   String
  userId     String
  memberRole MemberRole
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vendorId, userId])
  @@map("vendor_staff_assignments")
}

model Patient {
  id                 String                    @id @default(uuid())
  userId             String?                   @unique
  samagraId          String?                   @unique
  abhaId             String?                   @unique
  maskedSamagraId    String?
  maskedAbhaId       String?
  firstName          String
  lastName           String
  gender             Gender
  dob                DateTime
  age                Int
  phone              String
  addressLine        String
  village            String
  city               String
  districtId         String
  state              String
  pincode            String
  qrCodeValue        String?                   @unique
  qrCodeUrl          String?
  registrationStatus PatientRegistrationStatus @default(PENDING)
  approvedByAdminId  String?
  approvedAt         DateTime?
  rejectionReason    String?
  nextDueDate        DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  user              User?                 @relation(fields: [userId], references: [id])
  district          District              @relation(fields: [districtId], references: [id])
  approvedBy        Admin?                @relation(fields: [approvedByAdminId], references: [id])
  familyDetails     PatientFamilyDetail[]
  identityFetchLogs IdentityFetchLog[]
  visits            PatientCampVisit[]
  notifications     Notification[]

  @@map("patients")
}

model PatientFamilyDetail {
  id               String @id @default(uuid())
  patientId        String
  familyMemberName String
  relation         String
  age              Int

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_family_details")
}

model IdentityFetchLog {
  id              String   @id @default(uuid())
  patientId       String?
  sourceType      String // SAMAGRA or ABHA
  requestPayload  Json
  responsePayload Json
  fetchStatus     String
  createdAt       DateTime @default(now())

  patient Patient? @relation(fields: [patientId], references: [id])

  @@map("identity_fetch_logs")
}

model Camp {
  id            String            @id @default(uuid())
  vendorId      String
  campName      String
  venueName     String
  address       String
  districtId    String
  categoryScope CampCategoryScope
  scheduledDate DateTime
  startTime     DateTime
  endTime       DateTime
  status        CampStatus        @default(DRAFT)
  createdBy     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  vendor               Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  district             District                  @relation(fields: [districtId], references: [id])
  staffAssignments     CampStaffAssignment[]
  questionnaireConfigs CampQuestionnaireConfig[]
  visits               PatientCampVisit[]

  @@map("camps")
}

model CampStaffAssignment {
  id             String         @id @default(uuid())
  campId         String
  userId         String
  assignmentRole AssignmentRole
  assignedAt     DateTime       @default(now())

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campId, userId])
  @@map("camp_staff_assignments")
}

model QuestionnaireTier {
  id           String                @id @default(uuid())
  tierCode     QuestionnaireTierCode @unique
  title        String
  locationType String
  description  String
  isActive     Boolean               @default(true)

  questions QuestionnaireQuestion[]
  configs   CampQuestionnaireConfig[]

  @@map("questionnaire_tiers")
}

model QuestionnaireQuestion {
  id           String  @id @default(uuid())
  tierId       String
  questionKey  String
  questionText String
  inputType    String
  optionsJson  Json?
  sortOrder    Int
  isRequired   Boolean @default(false)
  isActive     Boolean @default(true)

  tier QuestionnaireTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@map("questionnaire_questions")
}

model CampQuestionnaireConfig {
  id               String  @id @default(uuid())
  campId           String
  tierId           String
  printTemplateUrl String?
  isActive         Boolean @default(true)

  camp Camp              @relation(fields: [campId], references: [id], onDelete: Cascade)
  tier QuestionnaireTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([campId, tierId])
  @@map("camp_questionnaire_configs")
}

model PatientCampVisit {
  id                  String            @id @default(uuid())
  patientId           String
  campId              String
  qrScannedBy         String
  scannedAt           DateTime          @default(now())
  eligibilityStatus   EligibilityStatus
  ineligibilityReason String?
  selectedCategory    CampCategoryScope
  tierId              String
  attendanceStatus    AttendanceStatus  @default(PRESENT)
  gpsLatitude         Float?
  gpsLongitude        Float?
  patientPhotoUrl     String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  camp       Camp        @relation(fields: [campId], references: [id], onDelete: Cascade)
  scannedBy  User        @relation(fields: [qrScannedBy], references: [id])
  assessment Assessment?
  report     Report?

  @@map("patient_camp_visits")
}

model Assessment {
  id                   String   @id @default(uuid())
  patientVisitId       String   @unique
  filledByFieldStaffId String
  tierId               String
  assessmentDataJson   Json
  bpSystolic           Float?
  bpDiastolic          Float?
  bloodSugar           Float?
  hemoglobin           Float?
  tobaccoUsage         Boolean?
  alcoholUsage         Boolean?
  symptomsJson         Json?
  capturedGpsLatitude  Float?
  capturedGpsLongitude Float?
  photoUrl             String?
  isOfflineEntry       Boolean  @default(false)
  submittedAt          DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  patientVisit PatientCampVisit @relation(fields: [patientVisitId], references: [id], onDelete: Cascade)
  filledBy     User             @relation(fields: [filledByFieldStaffId], references: [id])

  @@map("assessments")
}

model Report {
  id                       String       @id @default(uuid())
  patientVisitId           String       @unique
  assessedByDoctorId       String
  generatedPatientReportId String       @unique
  diagnosis                String
  prescription             String
  remarks                  String
  reportSummary            String
  reportStatus             ReportStatus @default(DRAFT)
  submittedAt              DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  patientVisit PatientCampVisit @relation(fields: [patientVisitId], references: [id], onDelete: Cascade)
  assessedBy   User             @relation(fields: [assessedByDoctorId], references: [id])
  documents    ReportDocument[]

  @@map("reports")
}

model ReportDocument {
  id         String   @id @default(uuid())
  reportId   String
  fileType   FileType
  fileUrl    String
  uploadedAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_documents")
}

model Notification {
  id              String          @id @default(uuid())
  patientId       String?
  userId          String?
  type            String
  title           String
  message         String
  deliveryChannel DeliveryChannel
  isRead          Boolean         @default(false)
  sentAt          DateTime?
  createdAt       DateTime        @default(now())

  patient Patient? @relation(fields: [patientId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String
  actorRole    UserRole
  action       String
  entityType   String
  entityId     String
  ipAddress    String
  metadataJson Json
  createdAt    DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id])

  @@map("audit_logs")
}

model LoginSession {
  id         String    @id @default(uuid())
  userId     String
  loginAt    DateTime  @default(now())
  logoutAt   DateTime?
  ipAddress  String
  deviceInfo String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_sessions")
}
